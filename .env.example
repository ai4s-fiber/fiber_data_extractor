DATABASE_URL=sqlite+aiosqlite:///./fiber_data.db
ALLOW_SQLITE_FALLBACK=true
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
PARSE_ARTIFACT_DIR=./parse_artifacts
MINERU_ENABLED=true
MINERU_API_URL=http://127.0.0.1:8001
MINERU_CLOUD_TOKEN=
MINERU_CLOUD_TRUST_ENV=true
MINERU_CLOUD_MODEL_VERSION=vlm
MINERU_CLOUD_PAGE_RANGES=
MINERU_CLOUD_ENABLE_FORMULA=true
MINERU_CLOUD_ENABLE_TABLE=true
MINERU_CLOUD_IS_OCR=false
MINERU_REUSE_PARSE_ARTIFACTS=true
MINERU_CLOUD_FALLBACK_LOCAL=false
MINERU_FALLBACK_LEGACY_PARSER=false
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
MINERU_IMAGE_ANALYSIS_ENABLE=true
MINERU_HYBRID_EFFORT=medium
DEFAULT_PARSER_STRATEGY=mineru_cloud
DEFAULT_LLM_PROVIDER=openai
DEFAULT_LLM_BASE_URL=https://aigw.sotatts.online/v1
DEFAULT_LLM_MODEL=gpt-5.5
EXTRACTION_MAX_CONCURRENT_JOBS=2
STRONG_LLM_PARALLEL_CALLS=4
LLM_GLOBAL_MAX_CONCURRENT_CALLS=12
LLM_BATCH_MAX_CONCURRENT_CALLS=8
LLM_INTERACTIVE_RESERVED_CALLS=4

# Docker Compose PostgreSQL settings
POSTGRES_DB=fiber_v6
POSTGRES_USER=fiber
POSTGRES_PASSWORD=change-me-before-deploy
