DATABASE_URL=sqlite+aiosqlite:///./fiber_data.db
ALLOW_SQLITE_FALLBACK=true
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379/0
UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
PARSE_ARTIFACT_DIR=./parse_artifacts
MINERU_ENABLED=false
MINERU_API_URL=http://127.0.0.1:8001
MINERU_CLOUD_TOKEN=
DEFAULT_PARSER_STRATEGY=legacy

# Docker Compose PostgreSQL settings
POSTGRES_DB=fiber_v6
POSTGRES_USER=fiber
POSTGRES_PASSWORD=change-me-before-deploy
